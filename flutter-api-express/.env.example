# Database connection (DATABASE_URL is built from these at runtime, see src/db.js)
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD="DB_PASSWORD"
DB_NAME="flutter_db"

# JWT auth (used by both the mobile app and the web-admin)
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS: comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://52.221.205.240:2000"
